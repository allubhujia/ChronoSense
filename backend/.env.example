# Copy this file to ".env" and adjust if needed.

# MongoDB connection
MONGO_URI=mongodb://localhost:27017
MONGO_DB=chronosense
RADAR_COLLECTION=radar_captures
LABEL_COLLECTION=labels

# Where the processed dataset lives (relative to the backend/ folder).
# This is only used by the ingest script to find the two index JSON files.
DATASET_ROOT=../FMCW_dataset
